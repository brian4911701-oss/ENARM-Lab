    "questions": [
      {
        "question": "De acuerdo con las indicaciones de la GPC, ¿cuál es el procedimiento quirúrgico de elección (estándar de oro) para esta paciente con ERGE refractario y presencia de hernia hiatal?",
        "options": [
          "Funduplicatura parcial tipo Toupet (270°)",
          "Funduplicatura total tipo Nissen (360°)",
          "Cardiomiotomía de Heller",
          "Bypass gástrico en Y de Roux"
        ],
